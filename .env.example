# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed.
# Loaded automatically by `tests/integration/conftest.py` for the
# integration suite. Existing environment values are NOT overridden,
# so CI secrets / explicit shell exports still win.

# monday.com API token used by the `mondo` CLI for live calls.
MONDAY_API_TOKEN=__paste_token_here__

# Mirrored token that gates the live integration suite. Tests under
# tests/integration/ skip unless this is set; setting it explicitly
# expresses opt-in to mutating real resources.
MONDAY_TEST_TOKEN=__paste_token_here__

# Live playground board (created once, reused across tests).
MONDO_TEST_BOARD_NAME=Mondo Test Board
MONDO_TEST_BOARD_ID=5094861043
MONDO_TEST_BOARD_URL=https://marktguru.monday.com/boards/5094861043

# Workspace that owns the playground board / docs. Two names because
# the original fixture reads MONDAY_TEST_WORKSPACE_ID, while the rest
# of the project uses the MONDO_-prefixed form.
MONDO_TEST_WORKSPACE_ID=592446
MONDAY_TEST_WORKSPACE_ID=592446

# Pre-prepared doc with notice-box blocks, used by read-only doc tests.
MONDO_TEST_DOC_ID=5095668848
MONDO_TEST_DOC_URL=https://marktguru.monday.com/docs/5095668848
